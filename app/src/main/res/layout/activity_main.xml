<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ═══ HEADER ═══ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@color/bg_dark">

                <!-- Glow blob -->
                <View
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center_horizontal|top"
                    android:layout_marginTop="-80dp"
                    android:background="@drawable/bg_header_glow"
                    android:alpha="0.6" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="24dp">

                    <!-- Icon circle -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_button_gradient"
                            android:alpha="0.15" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="⚡"
                            android:textSize="30sp"
                            android:gravity="center" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RUIJIE PRO"
                        android:textColor="@color/cyan_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:fontFamily="sans-serif-condensed" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Myanmar Network Login Tool"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ═══ GATEWAY CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_chip"
                    android:padding="10dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvGatewayInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No saved gateway"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Clear gateway icon button -->
                <FrameLayout
                    android:id="@+id/btnClearGateway"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_chip"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="🗑"
                        android:textSize="16sp"
                        android:gravity="center" />
                </FrameLayout>
            </LinearLayout>

            <!-- ═══ MAIN CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:marginHorizontal="16dp"
                android:padding="20dp"
                android:layout_marginBottom="12dp">

                <!-- Voucher Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VOUCHER CODE"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Voucher Input Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:background="@color/bg_surface"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/etVoucher"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="Enter voucher code..."
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:singleLine="true" />

                    <!-- Paste button -->
                    <FrameLayout
                        android:id="@+id/btnPasteVoucher"
                        android:layout_width="52dp"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="📋"
                            android:textSize="18sp"
                            android:gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Connect Button -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp">

                    <!-- Gradient background layer -->
                    <View
                        android:id="@+id/btnConnectBg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_gradient" />

                    <Button
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="⚡  CONNECT"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/bg_dark"
                        android:elevation="0dp"
                        android:stateListAnimator="@null" />
                </FrameLayout>
            </LinearLayout>

            <!-- ═══ PROGRESS BAR ═══ -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/cyan_primary"
                android:visibility="gone"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp" />

            <!-- ═══ STATUS CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_status"
                android:marginHorizontal="16dp"
                android:padding="14dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvStatusIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="⏳"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Voucher Code ထည့်ပြီး Connect နှိပ်ပါ"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- ═══ LOG TERMINAL CARD ═══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:marginHorizontal="16dp"
                android:layout_marginBottom="8dp">

                <!-- Terminal header bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:background="@color/bg_surface">

                    <!-- Traffic lights -->
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#FF5F57"
                        android:layout_marginEnd="6dp" />
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#FEBC2E"
                        android:layout_marginEnd="6dp" />
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="#28C840"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ruijie-pro — output"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/btnClearLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✕ clear"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp" />
                </LinearLayout>

                <!-- Log output -->
                <ScrollView
                    android:id="@+id/scrollLog"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@color/log_bg"
                    android:padding="12dp"
                    android:overScrollMode="never"
                    android:fadeScrollbars="false">

                    <TextView
                        android:id="@+id/tvLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$ ready...\n"
                        android:textColor="@color/log_text"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="3dp" />
                </ScrollView>
            </LinearLayout>

            <!-- ═══ VERSION FOOTER ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ruijie Pro v1.0 · Myanmar Network Tool"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:gravity="center"
                android:paddingTop="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
